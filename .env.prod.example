# Hizal — Production Environment
# Copy to .env and fill in all values before running.

# Server
PORT=8080
ENV=production
# Comma-separated list of allowed origins (e.g., "https://your-domain.com")
CORS_ALLOW_ORIGINS=https://your-domain.com

# Database (PostgreSQL with pgvector)
POSTGRES_USER=hizal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hizal
DATABASE_URL=postgres://hizal:changeme@hizal-postgres:5432/hizal?sslmode=disable

# App URLs
APP_BASE_URL=https://your-domain.com

# Email (SMTP)
EMAIL_FROM=noreply@your-domain.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=you@your-domain.com
SMTP_PASSWORD=yourpassword

# OpenAI (required for embeddings)
OPENAI_API_KEY=sk-...

# Stripe (optional — only needed for paid tier)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_SUCCESS_URL=https://your-domain.com/workspace/:orgId?upgraded=true
STRIPE_CANCEL_URL=https://your-domain.com/workspace/:orgId

# Security — generate with: openssl rand -hex 32
JWT_SECRET=changeme